# Copy this file to .env and adjust values.
# Local development: GALAXY_API_URL=http://localhost:8000
# Docker: GALAXY_API_URL=http://host.docker.internal:8000

# Orchestration mode: direct (Galaxy API), n8n (n8n webhook), or auto (LLM router; requires OPENAI_API_KEY).
ORCHESTRATOR_MODE=direct
GALAXY_API_URL=http://localhost:8000
GALAXY_API_KEY=
N8N_WEBHOOK_URL=
# URL del webhook de n8n al que se envia el feedback del usuario (rating + comentario).
# Apunta a un workflow separado que escribe en la pestania "feedback" de la hoja de logs.
N8N_FEEDBACK_WEBHOOK_URL=
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# OpenAI, required for auto mode.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
